aws_region          = "us-east-1"
project_name        = "redbus"
environment         = "prod"
ssh_public_key      = "ssh-rsa REPLACE_WITH_PUBLIC_KEY redbus-ec2"
ssh_allowed_cidr    = "YOUR_PUBLIC_IP/32"

github_repository  = "YOUR_GITHUB_USER/redbus-project"
github_oauth_token = "set-this-from-jenkins-or-env-not-in-git"
amplify_branch     = "main"

# Leave empty to use the Terraform-created API Gateway HTTPS proxy.
# Use https://api.example.com only after you configure a backend domain and TLS.
backend_url = ""
